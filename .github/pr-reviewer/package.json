{
  "name": "@domesco/pr-reviewer",
  "version": "2.0.0",
  "description": "Multi-platform PR/MR code reviewer powered by OpenCode",
  "type": "module",
  "bin": {
    "pr-reviewer": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --test dist/**/*.test.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["code-review", "opencode", "github", "gitlab", "bitbucket", "ai"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DomEscobar/PR-reviewer-Example"
  }
